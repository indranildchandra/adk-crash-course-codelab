# Copy this file to .env and fill in your values.
# Choose ONE authentication method below.

# --- Option 1: Vertex AI (Google Cloud) ---
# Recommended for production. Requires gcloud auth and a GCP project.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Option 2: Gemini API Key ---
# Simpler for local development. Get a key at https://console.cloud.google.com/apis/api/generativelanguage.googleapis.com/credentials >> Gemini API >> Credentials >> Create credentials
# Comment out the Vertex AI block above and uncomment below block:
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your-gemini-api-key

# Model configuration for ADK agents
# Change MODEL_PROVIDER and MODEL_NAME here to switch models globally.
# No code changes needed — just update this file and restart.

# --- Option 1: Gemini via Vertex AI or API key (default) ---
# MODEL_PROVIDER=gemini
# MODEL_NAME=gemini-2.5-flash

# --- Option 2: Local Ollama model ---
# Requires Ollama running: https://ollama.com
# NOTE: Model MUST support tool calling - e.g. gemma3 does NOT support tools on Ollama and hence cannot be used.
# Recommended models (all support tool calling):
#   gemma4:e2b   (~7.2GB) — Gemma 4, tools supported, good for 16GB RAM Macs
#   gemma4       (~9.6GB) — Gemma 4 default (e4b), better quality, needs 16GB+ RAM
#   qwen2.5:7b   (~4.7GB) — best tool-calling reliability among smaller models
#   llama3.2:3b  (~2GB)   — fastest, good for testing
#   llama3.1:8b  (~4.7GB) — strong overall quality
#   mistral:7b   (~4.1GB) — solid alternative
MODEL_PROVIDER=ollama
MODEL_NAME=gemma4:e2b
OLLAMA_API_BASE=http://localhost:11434

# --- Judge Model (used by tests/run_tests.py) ---
# Evaluates agent responses offline — no API costs.
# Must be an Ollama model with strong reasoning ability.
# Recommended: qwen2.5:7b (~4.7GB) — pulled automatically if missing.
JUDGE_PROVIDER=ollama
JUDGE_MODEL=qwen2.5:7b

# --- Test Runner ---
# TEST_TIMEOUT_SECONDS=300   # per-test wall-clock timeout (default 300s)
# LLM_TIMEOUT_SECONDS=180    # per-LLM-call cap for Ollama (default 180s)
#                              Keeps timed-out background threads from blocking the next test.
